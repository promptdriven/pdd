{
    "taskGroups": [
        {
            "taskSpec": {
                "runnables": [
                    {
                        "container": {
                            "imageUri": "{{REGION}}-docker.pkg.dev/{{PROJECT_ID}}/pdd-ci/pdd-test:latest",
                            "entrypoint": "/runtime-secrets.py"
                        },
                        "environment": {
                            "variables": {
                                "VERTEX_PROJECT": "{{PROJECT_ID}}",
                                "PDD_TEST_HEADLESS": "1",
                                "GCS_BUCKET_NAME": "litellm_cache",
                                "TASK_INDEX_OFFSET": "68",
                                "PDD_CLOUD_URL": "https://{{REGION}}-{{PROJECT_ID}}.cloudfunctions.net",
                                "PDD_ENV": "staging",
                                "PDD_CLOUD_TIMEOUT": "1200",
                                "PYTEST_CHUNK_TIMEOUT": "1800",
                                "GCS_HMAC_ACCESS_KEY_ID_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/GCS_HMAC_ACCESS_KEY_ID/versions/latest",
                                "GCS_HMAC_SECRET_ACCESS_KEY_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/GCS_HMAC_SECRET_ACCESS_KEY/versions/latest",
                                "OPENAI_API_KEY_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/OPENAI_API_KEY/versions/latest",
                                "FIREBASE_API_KEY_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/staging-firebase-api-key/versions/latest",
                                "GITHUB_CLIENT_ID_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/github-client-id/versions/latest",
                                "PDD_REFRESH_TOKEN_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/pdd-refresh-token/versions/latest",
                                "CLAUDE_CODE_OAUTH_TOKEN_SECRET_RESOURCE": "projects/{{PROJECT_ID}}/secrets/CLAUDE_CODE_OAUTH_TOKEN/versions/latest"
                            }
                        }
                    }
                ],
                "volumes": [
                    {
                        "gcs": {
                            "remotePath": "{{RESULTS_GCS_PATH}}"
                        },
                        "mountPath": "/mnt/disks/results"
                    },
                    {
                        "gcs": {
                            "remotePath": "{{SOURCE_GCS_PATH}}"
                        },
                        "mountPath": "/mnt/disks/source"
                    }
                ],
                "maxRetryCount": 2,
                "maxRunDuration": "5400s",
                "lifecyclePolicies": [
                    {
                        "action": "RETRY_TASK",
                        "actionCondition": {
                            "exitCodes": [50001, 50002, 50003, 50006]
                        }
                    }
                ]
            },
            "taskCount": "8",
            "parallelism": "1"
        }
    ],
    "allocationPolicy": {
        "instances": [
            {
                "policy": {
                    "machineType": "e2-standard-8",
                    "provisioningModel": "STANDARD"
                }
            }
        ],
        "serviceAccount": {
            "email": "pdd-ci-batch@{{PROJECT_ID}}.iam.gserviceaccount.com"
        },
        "location": {
            "allowedLocations": ["regions/{{REGION}}"]
        }
    },
    "logsPolicy": {
        "destination": "CLOUD_LOGGING"
    }
}
