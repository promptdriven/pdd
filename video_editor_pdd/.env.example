# Google GenAI API key (for Veo 3.1 and Imagen 3.0)
GOOGLE_API_KEY=

# Path to your video project directory (defaults to cwd if not set)
PROJECT_DIR=

# Optional: override the default Remotion project path
REMOTION_DIR=

# Optional: AWS Lambda rendering (Stage 9 — disabled by default)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
REMOTION_LAMBDA_FUNCTION_NAME=
