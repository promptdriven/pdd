version: "1.0"

contexts:
  # ============================================================
  # TYPES & CONFIG
  # ============================================================

  types:
    paths: ["*types_TypeScript*"]
    defaults:
      outputs:
        code:
          path: "lib/types.ts"
        prompt:
          path: "prompts/types_TypeScript.prompt"

  next_config:
    paths: ["*next_config*"]
    defaults:
      outputs:
        code:
          path: "next.config.ts"
        prompt:
          path: "prompts/next_config_TypeScript.prompt"

  package_json:
