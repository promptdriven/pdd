    defaults:
      outputs:
        code:
          path: "tsconfig.json"
        prompt:
          path: "prompts/tsconfig_json_JSON.prompt"

  # ============================================================
  # PYTHON SCRIPTS
  # ============================================================

  render_tts:
    paths: ["*render_tts*"]
    defaults:
      outputs:
        code:
          path: "scripts/render_tts.py"
        prompt:
          path: "prompts/render_tts_Python.prompt"

