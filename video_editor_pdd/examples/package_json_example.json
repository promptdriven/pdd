{
  "private": true,
  "name": "video-editor-pdd-example",
  "version": "0.1.0",
  "description": "Example project showing how to use the video-editor-pdd package.json to bootstrap a Next.js 15 video production pipeline editor.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "npm install && npm run dev",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "_comments": {
    "overview": [
      "This file demonstrates the intended usage of the video-editor-pdd package.json.",
      "",
      "=== STEP 1: Project Initialization ===",
      "  mkdir video-editor-pdd && cd video-editor-pdd",
      "  Copy the package.json (the code module) into this directory.",
      "  Ensure Node.js >= 20 is installed (required by the 'engines' field).",
      "  Run: npm install",
      "",
      "=== STEP 2: Tailwind CSS v4 Setup (no tailwind.config.js needed) ===",
      "  Create app/globals.css with:",
      "    @import 'tailwindcss';",
      "  Tailwind v4 uses CSS-first configuration; no postcss or autoprefixer needed.",
      "",
      "=== STEP 3: App Router Structure ===",
      "  Create the Next.js App Router layout:",
      "    app/layout.tsx    — Root layout importing globals.css",
      "    app/page.tsx      — Home page (video project list)",
      "    app/editor/page.tsx — Video editor UI",
      "    app/api/render/route.ts — API route for server-side Remotion rendering",
      "    app/api/generate/route.ts — API route for Gemini AI script generation",
      "",
      "=== STEP 4: Key Dependency Usage Patterns ==="
    ],
    "dependency_usage": {
      "remotion_and_renderer": [
        "// app/api/render/route.ts — Server-side video rendering",
        "import { bundle } from '@remotion/bundler';       // bundle Remotion compositions",
        "import { renderMedia, selectComposition } from '@remotion/renderer';",
        "",
        "// 1. Bundle your Remotion project (contains <Composition> definitions)",
        "const bundleLocation = await bundle({ entryPoint: './remotion/index.ts' });",
        "",
        "// 2. Select a composition by ID",
        "const composition = await selectComposition({",
        "  serveUrl: bundleLocation,",
        "  id: 'MyVideo',",
        "  inputProps: { title: 'Hello World' },",
        "});",
        "",
        "// 3. Render to MP4",
        "await renderMedia({",
        "  composition,",
        "  serveUrl: bundleLocation,",
        "  codec: 'h264',",
        "  outputLocation: './output/video.mp4',",
        "  inputProps: { title: 'Hello World' },",
        "});"
      ],
      "google_generative_ai": [
        "// app/api/generate/route.ts — AI-powered script generation",
        "import { GoogleGenerativeAI } from '@google/generative-ai';",
        "",
        "const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY!);",
        "const model = genAI.getGenerativeModel({ model: 'gemini-1.5-pro' });",
        "",
        "// Generate a video script from a prompt",
        "const result = await model.generateContent(",
        "  'Write a 60-second video script about climate change'",
        ");",
        "const scriptText = result.response.text();",
        "// Returns: string — the generated script markdown"
      ],
      "better_sqlite3": [
        "// lib/db.ts — Project metadata storage",
        "import Database from 'better-sqlite3';",
        "",
        "// Input: database file path (string), relative to project root",
        "// Output: Database instance with typed query methods",
        "const db = new Database('./data/projects.db');",
        "",
        "// Create projects table",
        "db.exec(`CREATE TABLE IF NOT EXISTS projects (",
        "  id INTEGER PRIMARY KEY AUTOINCREMENT,",
        "  name TEXT NOT NULL,",
        "  script TEXT,",
        "  status TEXT DEFAULT 'draft',",
        "  created_at DATETIME DEFAULT CURRENT_TIMESTAMP",
        ")`);",
        "",
        "// Insert a project",
        "// Input: name (string) — project name",
        "// Output: { changes: number, lastInsertRowid: number }",
        "const insert = db.prepare('INSERT INTO projects (name) VALUES (?)');",
        "const info = insert.run('My Video Project');",
        "",
        "// Query all projects",
        "// Output: Array<{ id: number, name: string, script: string|null, status: string }>",
        "const projects = db.prepare('SELECT * FROM projects').all();"
      ],
      "wavesurfer_js": [
        "// components/AudioWaveform.tsx — Client-side audio visualization",
        "'use client';",
        "import { useEffect, useRef } from 'react';",
        "import WaveSurfer from 'wavesurfer.js';",
        "",
        "// Input props:",
        "//   audioUrl: string — URL or path to the audio file",
        "//   onReady: () => void — callback when waveform is loaded",
        "// Output: renders an interactive waveform in a div",
        "export default function AudioWaveform({ audioUrl }: { audioUrl: string }) {",
        "  const containerRef = useRef<HTMLDivElement>(null);",
        "  useEffect(() => {",
        "    if (!containerRef.current) return;",
        "    const ws = WaveSurfer.create({",
        "      container: containerRef.current,",
        "      waveColor: '#4F46E5',",
        "      progressColor: '#818CF8',",
        "      url: audioUrl,",
        "    });",
        "    return () => ws.destroy();",
        "  }, [audioUrl]);",
        "  return <div ref={containerRef} />;",
        "}"
      ],
      "codemirror": [
        "// components/ScriptEditor.tsx — Markdown script editor",
        "'use client';",
        "import { useEffect, useRef } from 'react';",
        "import { EditorView } from '@codemirror/view';",
        "import { EditorState } from '@codemirror/state';",
        "import { basicSetup } from '@codemirror/basic-setup';",
        "import { markdown } from '@codemirror/lang-markdown';",
        "",
        "// Input props:",
        "//   initialDoc: string — initial markdown content",
        "//   onChange: (content: string) => void — called on every edit",
        "// Output: renders a CodeMirror 6 editor with markdown syntax highlighting",
        "export default function ScriptEditor({ initialDoc, onChange }: {",
        "  initialDoc: string; onChange: (s: string) => void;",
        "}) {",
        "  const editorRef = useRef<HTMLDivElement>(null);",
        "  useEffect(() => {",
        "    if (!editorRef.current) return;",
        "    const view = new EditorView({",
        "      state: EditorState.create({",
        "        doc: initialDoc,",
        "        extensions: [",
        "          basicSetup,",
        "          markdown(),",
        "          EditorView.updateListener.of((update) => {",
        "            if (update.docChanged) onChange(update.state.doc.toString());",
        "          }),",
        "        ],",
        "      }),",
        "      parent: editorRef.current,",
        "    });",
        "    return () => view.destroy();",
        "  }, []);",
        "  return <div ref={editorRef} className='border rounded-lg' />;",
        "}"
      ],
      "zod": [
        "// lib/schemas.ts — Runtime validation for API inputs/outputs",
        "import { z } from 'zod';",
        "",
        "// Input schema for creating a render job",
        "// Input fields:",
        "//   projectId: number — ID of the project in SQLite",
        "//   compositionId: string — Remotion composition ID",
        "//   outputFormat: 'mp4' | 'webm' — desired output codec",
        "//   fps: number (1-120) — frames per second",
        "export const RenderJobSchema = z.object({",
        "  projectId: z.number().int().positive(),",
        "  compositionId: z.string().min(1),",
        "  outputFormat: z.enum(['mp4', 'webm']),",
        "  fps: z.number().min(1).max(120).default(30),",
        "});",
        "",
        "// Output: typed object matching the schema",
        "type RenderJob = z.infer<typeof RenderJobSchema>;",
        "",
        "// Usage in an API route:",
        "// const body = await request.json();",
        "// const parsed = RenderJobSchema.parse(body);  // throws ZodError if invalid",
        "// const safe = RenderJobSchema.safeParse(body); // returns { success, data?, error? }"
      ],
      "python_subprocesses": [
        "// lib/python.ts — Invoking Python pipeline scripts",
        "import { spawn } from 'child_process';",
        "",
        "// Input:",
        "//   scriptPath: string — relative path to Python script (e.g., 'scripts/render_tts.py')",
        "//   args: string[] — CLI arguments to pass to the script",
        "// Output: Promise<string> — stdout from the Python process",
        "export function runPython(scriptPath: string, args: string[]): Promise<string> {",
        "  return new Promise((resolve, reject) => {",
        "    const proc = spawn('python3', [scriptPath, ...args]);",
        "    let stdout = '';",
        "    let stderr = '';",
        "    proc.stdout.on('data', (d) => (stdout += d.toString()));",
        "    proc.stderr.on('data', (d) => (stderr += d.toString()));",
        "    proc.on('close', (code) =>",
        "      code === 0 ? resolve(stdout) : reject(new Error(stderr))",
        "    );",
        "  });",
        "}",
        "",
        "// Example calls from API routes:",
        "// await runPython('scripts/render_tts.py', ['--text', scriptText, '--output', 'audio.wav']);",
        "// await runPython('scripts/sync_audio_pipeline.py', ['--project-id', '42']);",
        "// await runPython('scripts/generate_section_compositions.py', ['--config', 'sections.json']);"
      ]
    },
    "project_structure": [
      "Recommended directory layout (relative to project root):",
      "",
      "video-editor-pdd/",
      "├── package.json              ← The code module (this manifest)",
      "├── tsconfig.json",
      "├── next.config.ts",
      "├── app/",
      "│   ├── globals.css           ← Contains: @import 'tailwindcss';",
      "│   ├── layout.tsx            ← Root layout",
      "│   ├── page.tsx              ← Home / project list",
      "│   ├── editor/",
      "│   │   └── page.tsx          ← Video editor with CodeMirror + WaveSurfer",
      "│   └── api/",
      "│       ├── render/route.ts   ← Remotion server-side rendering endpoint",
      "│       └── generate/route.ts ← Gemini AI generation endpoint",
      "├── components/",
      "│   ├── ScriptEditor.tsx      ← CodeMirror markdown editor",
      "│   └── AudioWaveform.tsx     ← WaveSurfer audio visualizer",
      "├── lib/",
      "│   ├── db.ts                 ← better-sqlite3 database setup",
      "│   ├── schemas.ts            ← Zod validation schemas",
      "│   └── python.ts             ← child_process Python runner",
      "├── remotion/",
      "│   └── index.ts              ← Remotion composition definitions",
      "├── scripts/",
      "│   ├── render_tts.py",
      "│   ├── sync_audio_pipeline.py",
      "│   └── generate_section_compositions.py",
      "├── data/",
      "│   └── projects.db           ← SQLite database file",
      "└── output/                   ← Rendered video output directory"
    ],
    "getting_started": [
      "1. Ensure Node.js >= 20 is installed: node --version",
      "2. Copy the package.json into your project root",
      "3. Run: npm install",
      "4. Create app/globals.css with: @import 'tailwindcss';",
      "5. Create app/layout.tsx importing globals.css",
      "6. Run: npm run dev",
      "7. Open http://localhost:3000",
      "",
      "Environment variables needed (.env.local):",
      "  GEMINI_API_KEY=your-google-ai-api-key"
    ]
  }
}