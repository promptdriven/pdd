<pdd-reason>Bounded agentic reviewer that follows local import/wrapper chains to collect capability-policy evidence for effects that deterministic checks miss.</pdd-reason>

<pdd-interface>
{
  "type": "module",
  "module": {
    "functions": [
      {
        "name": "run_agentic_reviewer",
        "signature": "(contract_effects: List[Dict], artifact_paths: List[Union[str, Path]], bounds: Optional[Dict] = None) -> List[Dict]",
        "returns": "List[Dict]"
      }
    ]
  }
}
</pdd-interface>

