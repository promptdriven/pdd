{
  "type": "module",
  "module": {
    "functions": [
      {"name": "prompt_lint", "description": "Lint prompts and user stories; exposed as pdd checkup lint with --review off|explain advisory pass"}
    ]
  }
}
</pdd-interface>

<pdd-dependency>prompt_lint_python.prompt</pdd-dependency>
<pdd-dependency>checkup_advisory_python.prompt</pdd-dependency>
