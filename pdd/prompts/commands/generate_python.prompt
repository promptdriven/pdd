<pdd-reason>CLI commands for generate/test/example; dry-run cost estimates are supported for standard generate only.</pdd-reason>
<pdd-interface>
{
  "type": "cli",
  "cli": {
    "commands": [
      {"name": "generate", "description": "Generate code from a prompt or trigger agentic architecture from a GitHub issue / route PRD modes; support standard dry-run estimates only for the prompt-file code generation path."},
      {"name": "test", "description": "Generate or enhance unit tests, generate/link prompt user stories, or generate deterministic offline regression tests from a user story (`--from-story`)."},
      {"name": "example", "description": "Generate context examples from prompt and code."}
    ]
  }
}
</pdd-interface>
<pdd-dependency>agentic_architecture_python.prompt</pdd-dependency>
<pdd-dependency>agentic_test_python.prompt</pdd-dependency>
