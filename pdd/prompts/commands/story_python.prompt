<pdd-interface>
{
  "type": "cli",
  "cli": {
    "commands": [
      {"name": "story add", "description": "Create a user story file from an issue URL, number, or local file, linked to one or more dev units or prompts"},
      {"name": "story list", "description": "List all user stories with their linked prompts and regression status"},
      {"name": "story link", "description": "Add a prompt link to an existing story file without regenerating the story body"}
    ]
  }
}
