<pdd-reason>Bridges a ChatGPT/Codex subscription into litellm's chatgpt/ provider as the default flat-rate llm_invoke route.</pdd-reason>

<pdd-interface>
{
  "type": "module",
  "module": {
    "functions": [
      {"name": "is_chatgpt_subscription_model", "signature": "(model_name) -> bool", "returns": "bool"},
      {"name": "bridge_codex_auth_for_litellm", "signature": "() -> bool", "returns": "bool"},
      {"name": "has_codex_subscription_auth", "signature": "() -> bool", "returns": "bool"},
      {"name": "apply_litellm_chatgpt_output_patch", "signature": "() -> bool", "returns": "bool"},
