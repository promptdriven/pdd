</language_format_csv>
<pdd.agentic_langtest>
    <include select="def:default_verify_cmd_for">context/agentic_langtest_example.py</include>
</pdd.agentic_langtest>

% Deliverable
Produce `pdd/get_test_command.py` with the public API and observable behavior above.
