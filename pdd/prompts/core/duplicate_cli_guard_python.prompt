<pdd-reason>Prevents accidental duplicate CLI invocations by persisting only successful runs within a configurable time window.</pdd-reason>

<pdd-interface>
{
  "type": "module",
  "module": {
    "functions": [
      {"name": "check_duplicate_before_subcommand", "signature": "(ctx)", "returns": "None"},
      {"name": "record_after_guarded_command", "signature": "(ctx, success: bool = True)", "returns": "None"},
      {"name": "save_last_run", "signature": "(project_root, record)", "returns": "None"}
    ]
  }
}
</pdd-interface>

<pdd-dependency>architecture_registry_python.prompt</pdd-dependency>
<pdd-dependency>agentic_langtest_python.prompt</pdd-dependency>
