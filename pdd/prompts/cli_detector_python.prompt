<pdd-reason>Detects and bootstraps agentic CLI tools, installation, and provider configuration for pdd setup.</pdd-reason>

<pdd-interface>
{
  "type": "module",
  "module": {
    "functions": [
      {"name": "detect_and_bootstrap_cli", "signature": "() -> List[CliBootstrapResult]", "returns": "List[CliBootstrapResult]"},
      {"name": "detect_cli_tools", "signature": "() -> None", "returns": "None"}
    ],
    "dataclasses": [
