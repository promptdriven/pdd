        "signature": "(path: Path, *, strength: float = 0.5, temperature: float = 0.0, time: Optional[float] = None, verbose: bool = False, use_cloud: Optional[bool] = None) -> list[LintIssue]",
        "returns": "list[LintIssue]"
      }
