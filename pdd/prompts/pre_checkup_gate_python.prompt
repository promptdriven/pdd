<pdd-reason>Single blocking pre-checkup gate that drift-syncs and build/smoke-verifies a PR before handing off to checkup --pr.</pdd-reason>

<pdd-interface>
{
  "type": "module",
  "module": {
    "functions": [
      {"name": "run_pre_checkup_gate", "signature": "(worktree: Path, changed_files: Sequence[str], *, base_ref: Optional[str] = None, repo_owner: str = '', repo_name: str = '', issue_number: Optional[int] = None, strict: Optional[bool] = None, quiet: bool = False, timeout_per_check: float = 300.0) -> Tuple[bool, str, float]", "returns": "Tuple[bool, str, float]"}
    ]
  }
}
</pdd-interface>

<pdd-dependency>checkup_gates_python.prompt</pdd-dependency>
<pdd-dependency>ci_drift_heal_python.prompt</pdd-dependency>
