{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptdriven.dev/schemas/evidence_manifest.schema.json",
  "title": "PDD Evidence Manifest",
  "type": "object",
  "required": ["schema_version", "run", "prompt", "context", "generation", "outputs", "contracts", "validation", "logs"],
  "properties": {
    "schema_version": {"type": "integer", "enum": [1, 2]},
    "run": {
      "type": "object",
      "required": ["id", "command", "pdd_version", "timestamp"],
      "properties": {
        "id": {"type": "string"},
        "command": {"type": "string"},
        "pdd_version": {"type": "string"},
        "timestamp": {"type": "string"}
      }
    },
    "prompt": {
      "type": "object",
      "required": ["path", "sha256", "expanded_sha256", "uses_nondeterministic_tags"],
      "properties": {
        "path": {"type": ["string", "null"]},
        "sha256": {"type": ["string", "null"]},
        "expanded_sha256": {"type": ["string", "null"]},
        "uses_nondeterministic_tags": {"type": "boolean"}
      }
    },
    "context": {
      "type": "object",
      "required": ["includes", "web_snapshots", "shell_snapshots"],
      "properties": {
        "includes": {"type": "array", "items": {"$ref": "#/$defs/fileHash"}},
        "web_snapshots": {"type": "array"},
        "shell_snapshots": {"type": "array"}
      }
    },
    "generation": {
      "type": "object",
      "required": ["model", "temperature", "cost_usd", "grounding_examples"],
      "properties": {
        "model": {"type": ["string", "null"]},
        "temperature": {"type": ["number", "null"]},
        "cost_usd": {"type": "number"},
        "grounding_examples": {"type": "array"},
        "grounding": {"$ref": "#/$defs/grounding"}
      }
    },
    "outputs": {"type": "array", "items": {"$ref": "#/$defs/fileHash"}},
    "contracts": {
      "type": "object",
      "required": ["status", "rules"],
      "properties": {
        "status": {"enum": ["available", "not_applicable", "not_available"]},
        "rules": {"type": "object"}
      }
    },
    "validation": {
      "type": "object",
      "required": ["detect_stories", "unit_tests", "verify"],
      "additionalProperties": {"type": "string"}
    },
    "logs": {
      "type": "object",
      "required": ["core_dump", "verify_results", "cost_csv"],
      "additionalProperties": {"type": ["string", "null"]}
    },
    "context_snapshot": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "manifest_path": {"type": ["string", "null"]},
        "snapshot_dir": {"type": ["string", "null"]},
        "expanded_prompt_path": {"type": ["string", "null"]},
        "expanded_sha256": {"type": ["string", "null"]},
        "expanded_prompt": {
          "type": ["object", "null"],
          "properties": {
            "path": {"type": "string"},
            "sha256": {"type": "string"},
            "redaction_applied": {"type": "boolean"}
          }
        },
        "uses_nondeterministic_context": {"type": "boolean"},
        "dynamic_tags": {"type": "array", "items": {"type": "string"}},
        "declared_dynamic_tags": {"type": "array", "items": {"type": "string"}},
        "redaction_applied": {"type": "boolean"},
        "artifacts": {"type": "array"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": 2}}, "required": ["schema_version"]},
      "then": {
        "properties": {
          "generation": {
            "required": ["model", "temperature", "cost_usd", "grounding_examples", "grounding"]
          }
        }
      }
    }
  ],
  "$defs": {
    "fileHash": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string"}
      }
    },
    "grounding": {
      "type": "object",
      "required": ["mode", "selected_examples", "pinned", "excluded", "reviewed"],
      "properties": {
        "mode": {"enum": ["cloud", "local", "unavailable"]},
        "selected_examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module"],
            "properties": {
              "module": {"type": "string"},
              "id": {"type": "string"},
              "title": {"type": "string"},
              "prompt_sha256": {"type": "string"},
              "code_sha256": {"type": "string"},
              "similarity": {"type": "number"},
              "source": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "pinned": {"type": "array", "items": {"type": "string"}},
        "excluded": {"type": "array", "items": {"type": "string"}},
        "reviewed": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  }
}
