    "target_upstream_path": "pdd/find_section.py",
    "visible_tests_upstream_path": "tests/test_find_section.py",
    "subsystem": "template/markdown postprocessing (pdd.postprocess_0 consumer)"
  },
  "core_path": "core",
  "pool_path": "pool",
  "target_files": ["src/pdd/find_section.py"],
  "allowed_edit_globs": ["src/pdd/**"],
  "task_brief_path": "task.md",
  "visible_tests": {
    "command": ["{python}", "-m", "pytest", "tests/visible", "-q"],
    "expected_exit_code": 0
  },
  "hidden_verifier": {
    "path": "hidden",
    "command": ["{python}", "-m", "pytest", ".", "-q"],
    "mounted_into_agent_sandbox": false
