  "oracle_edit": {
    "file": "src/pdd/find_section.py",
    "old": "found.append((language, start, len(lines)))",
    "new": "found.append((language, start, len(lines) - 1))"
  },
  "seed": {
    "target_site": "src/pdd/find_section.py:find_section (unclosed-block handling)",
    "bug_class": "off_by_one",
    "description": "unclosed fenced blocks report end index len(lines) — one past the final line — instead of len(lines) - 1; visible tests exercise only closed-block behavior"
  },
  "leak_denylist": [
    "find_section(lines) == [(\"python\", 1, 3)]",
    "find_section(lines) == [(\"toml\", 1, 1)]",
    "find_section(lines) == [(\"python\", 0, 5)]",
    "find_section(lines, start_index=3) == [(\"yaml\", 3, 4)]",
    "len(lines) - 1",
    "ends at the LAST line index"
  ]
