# LLM API Keys (at least one required)
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Additional LLM Providers (optional)
DEEPSEEK_API_KEY=your-deepseek-api-key
FIREWORKS_API_KEY=your-fireworks-api-key
GROQ_API_KEY=your-groq-api-key
TOGETHER_API_KEY=your-together-api-key

# Vertex AI (optional - for Gemini via GCP)
# ADC-first setup:
#   gcloud auth login
#   gcloud auth application-default login
#   gcloud config set project YOUR_GCP_PROJECT_ID
# Leave GOOGLE_APPLICATION_CREDENTIALS unset when using ADC.
VERTEXAI_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=us-central1
# Service-account key-file fallback only:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Legacy aliases also work:
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1

# PDD Configuration
PDD_PATH=/path/to/your/pdd/pdd
