  "segments": [
    {
      "start": 0.0,
      "end": 3.2,
      "text": "Your great-grandmother wasn't stupid for darning socks."
    },
    {
      "start": 4.08,
      "end": 5.66,
      "text": "The economics made it rational."
    },
    {
      "start": 6.94,
      "end": 9.38,
      "text": "And you're not stupid for patching code."
    },
    {
      "start": 10.04,
      "end": 12.64,
      "text": "Until now, the economics made it rational,"
    },
    {
      "start": 12.86,
      "end": 14.06,
      "text": "but the economics changed."
    },
    {
      "start": 14.54,
      "end": 19.28,
      "text": "And when economics change, behavior that was rational becomes..."
    },
    {
      "start": 19.28,
      "end": 20.16,
      "text": "Darning socks."
    },
    {
      "start": 22.26,
      "end": 23.04,
      "text": "Almana."
    },
    {
      "start": 23.54,
      "end": 23.82,
      "text": "Ugh."
    },
    {
      "start": 25.02,
      "end": 25.66,
      "text": "One more thing."
    },
    {
      "start": 26.38,
      "end": 28.36,
      "text": "This transition doesn't eliminate developers."
    },
    {
      "start": 28.36,
      "end": 29.9,
      "text": "It elevates them."
    },
    {
      "start": 31.18,
      "end": 34.58,
      "text": "Mole designers need deeper understanding than wood carvers."
    },
    {
      "start": 34.96,
      "end": 36.74,
      "text": "They need to understand materials,"
    },
    {
      "start": 37.3,
      "end": 39.72,
      "text": "physics, tolerances, failure modes."
    },
    {
      "start": 41.38,
      "end": 43.92,
      "text": "PDD developers work at the level of specification."
    },
    {
      "start": 44.66,
      "end": 46.22,
      "text": "You're not writing the defensive code."
    },
    {
      "start": 46.68,
      "end": 49.52,
      "text": "You're specifying what defensive behavior looks like."
    },
    {
      "start": 50.0,
      "end": 52.1,
      "text": "You're not implementing the error handling."
    },
    {
      "start": 52.56,
      "end": 54.82,
      "text": "You're defining the contract it must satisfy."
    },
    {
      "start": 54.82,
      "end": 60.28,
      "text": "The shift from implementation craft to specification craft."
    }
  ]
}