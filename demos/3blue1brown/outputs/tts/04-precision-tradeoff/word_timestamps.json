  "segments": [
    {
      "start": 0.0,
      "end": 3.24,
      "text": "Here's something subtle that changes how you think about prompts."
    },
    {
      "start": 5.04,
      "end": 6.74,
      "text": "In 3D printing, there's no mold."
    },
    {
      "start": 7.32,
      "end": 11.22,
      "text": "The machine must know exactly where to place every single point of material."
    },
    {
      "start": 11.78,
      "end": 14.24,
      "text": "The specification must be extremely precise."
    },
    {
      "start": 15.84,
      "end": 18.64,
      "text": "In injection molding, precision comes from the walls."
    },
    {
      "start": 19.26,
      "end": 21.44,
      "text": "The material just flows until it's constrained."
    },
    {
      "start": 23.8,
      "end": 26.02,
      "text": "This maps directly to PDD."
    },
    {
      "start": 26.96,
      "end": 31.44,
      "text": "With few tests, your prompt needs to specify everything."
    },
    {
      "start": 32.22,
      "end": 37.22,
      "text": "Edge cases, error handling, exact behavior in every situation."
    },
    {
      "start": 37.98,
      "end": 42.06,
      "text": "With many tests, the prompt only needs to specify intent."
    },
    {
      "start": 42.68,
      "end": 44.22,
      "text": "The tests handle the constraints."
    },
    {
      "start": 45.9,
      "end": 48.94,
      "text": "This is why test accumulation matters."
    },
    {
      "start": 49.58,
      "end": 51.36,
      "text": "It's not just about catching bugs."
    },
    {
      "start": 51.36,
      "end": 56.38,
      "text": "It's about making prompts simpler and regeneration safer over time."
    },
    {
      "start": 57.2,
      "end": 59.06,
      "text": "More tests, less prompt."
    },
    {
      "start": 59.6,
      "end": 61.38,
      "text": "The walls do the precision work."
    }
  ]
}