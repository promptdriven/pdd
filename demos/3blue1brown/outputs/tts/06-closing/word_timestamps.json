  "segments": [
    {
      "start": 0.0,
      "end": 1.16,
      "text": "So here's the mental shift."
    },
    {
      "start": 2.7,
      "end": 5.06,
      "text": "You don't patch socks because socks got cheap."
    },
    {
      "start": 5.64,
      "end": 7.62,
      "text": "The economics made patching irrational."
    },
    {
      "start": 9.36,
      "end": 10.74,
      "text": "Code just got that cheap."
    },
    {
      "start": 13.02,
      "end": 14.46,
      "text": "Prompts in code intent."
    },
    {
      "start": 15.28,
      "end": 16.66,
      "text": "Tests preserve behavior."
    },
    {
      "start": 17.4,
      "end": 19.06,
      "text": "Grounding maintains style."
    },
    {
      "start": 20.66,
      "end": 24.66,
      "text": "Code is generated, verified, and disposable."
    },
    {
      "start": 26.9,
      "end": 29.0,
      "text": "The code is just plastic."
    },
    {
      "start": 30.48,
      "end": 33.22,
      "text": "The mold is what matters."
    }
  ]
