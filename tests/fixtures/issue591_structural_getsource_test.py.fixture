"""Fixture: real pre-existing structural test pattern (issue #591).

This uses inspect.getsource + string matching and SHOULD be flagged.
Copied from test_pdd_executor.py in promptdriven/pdd_cloud (pre-existing,
not generated by pdd-bug).
"""

import inspect

from src.workers import pdd_executor


def test_issue613_binary_output_sanitization():
    """Issue #6: binary/control chars in subprocess output should be sanitized."""
    source = inspect.getsource(pdd_executor.run_pdd_command)
    has_sanitization = "isprintable" in source or "sanitized" in source
    assert has_sanitization, (
        "run_pdd_command's read_stream must filter non-printable "
        "control characters from subprocess output."
    )


def test_issue614_zero_cost_step_failure_logged_as_warning():
    """Issue #5: zero-cost step failures should be logged as warnings."""
    source = inspect.getsource(pdd_executor.run_pdd_command)
    has_zero_cost_check = "failed. Cost: $0.00" in source
    assert has_zero_cost_check, (
        "run_pdd_command must detect zero-cost step failures."
    )

    has_warning_log = "Zero-cost step failure" in source or "LLM may not have been called" in source
    assert has_warning_log, (
        "run_pdd_command must log a WARNING for zero-cost step failures."
    )
